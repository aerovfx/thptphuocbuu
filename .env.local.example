# Local Development Environment Variables
# Copy this file to .env.local and update with your local settings

# ============================================
# DATABASE
# ============================================
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/phuocbuu_local"

# ============================================
# NEXTAUTH
# ============================================
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-local-secret-key-change-this"

# ============================================
# GOOGLE OAUTH
# ============================================
# Get these from Google Cloud Console -> APIs & Services -> Credentials
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ============================================
# GOOGLE CLOUD STORAGE (GCS)
# ============================================
# Used for uploads (avatars, attachments, post images, videos)
# Project ID: gen-lang-client-0753799782 (thptphuocbuu)
GOOGLE_CLOUD_PROJECT_ID="gen-lang-client-0753799782"

# Bucket name specifically created for media storage
GCS_BUCKET_NAME="gen-lang-client-0753799782_cloudbuild"

# Optional locally if your local Google SDK is authenticated (gcloud auth application-default login)
# GOOGLE_APPLICATION_CREDENTIALS="/absolute/path/to/your-service-account-key.json"

# ============================================
# JWT (For Mobile App Authentication)
# ============================================
JWT_SECRET="your-jwt-secret-change-this"

# ============================================
# NOTES
# ============================================
# - PostgreSQL running locally does not strictly require connection pooling.
# - GCS requires either `GOOGLE_APPLICATION_CREDENTIALS` or a valid `gcloud auth application-default login` on your machine.
