# Local Development Environment Variables
# Copy this file to .env.local and update with your local settings

# ============================================
# DATABASE
# ============================================
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/phuocbuu_local"

# ============================================
# NEXTAUTH
# ============================================
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-local-secret-key-change-this"

# ============================================
# GOOGLE OAUTH (Copy từ .env production)
# ============================================
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ============================================
# CLOUDINARY (Copy từ .env production)
# ============================================
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# ============================================
# JWT (Cho Mobile App)
# ============================================
JWT_SECRET="your-jwt-secret-change-this"

# ============================================
# OPTIONAL: Email (Nếu test email features)
# ============================================
# EMAIL_SERVER_USER="your-email@gmail.com"
# EMAIL_SERVER_PASSWORD="your-app-password"
# EMAIL_FROM="noreply@localhost"

# ============================================
# OPTIONAL: Redis (Nếu dùng caching)
# ============================================
# REDIS_URL="redis://localhost:6379"

# ============================================
# NOTES
# ============================================
# - PostgreSQL local không cần pooling connection
# - Không cần Prisma Data Proxy cho local dev
# - JWT_SECRET chỉ dùng cho mobile app testing
# - Email settings tùy chọn, có thể skip nếu không test email
