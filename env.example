# AI Content Generator
# Choose provider: auto, grok, openrouter, openai, cursor, ollama, demo
AI_PROVIDER="auto"

# Grok API (X.AI) - Fast, powerful, and affordable
# Get API key from: https://console.x.ai
GROK_API_KEY="xai-your-api-key-here"

# OpenRouter - Unified Interface for 500+ AI Models
# Access GPT-5, Claude 4.5, Gemini 2.5 Pro, and more through one API
# Get API key from: https://openrouter.ai
# Recommended: Best balance of features, pricing, and availability
OPENROUTER_API_KEY="sk-or-v1-your-api-key-here"
OPENROUTER_MODEL="anthropic/claude-3.5-sonnet"
# Popular models:
# - "anthropic/claude-3.5-sonnet" (default, excellent quality)
# - "openai/gpt-5" (highest quality, premium cost)
# - "google/gemini-2.5-pro" (fast and powerful)
# - "openai/gpt-3.5-turbo" (cheapest, good for chat)
# - "x-ai/grok-2" (Grok via OpenRouter)
# Full list: https://openrouter.ai/models

# OpenAI API (GPT-4 Direct)
# Get API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY="sk-proj-your-api-key-here"

# Cursor API
CURSOR_API_KEY="your-cursor-api-key"

# Ollama (Local AI - Free & Private)
OLLAMA_URL="http://localhost:11434"
OLLAMA_MODEL="llama3.2:latest"

# AI System Configuration (Optional)
AI_CACHE_MAX_SIZE="1000"
AI_CACHE_TTL="86400000"
AI_MAX_CONSECUTIVE_FAILURES="3"
AI_CIRCUIT_BREAKER_TIMEOUT="60000"
