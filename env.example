# Database
DATABASE_URL="postgresql://username:password@localhost:5432/lmsmath"

# Supabase
SUPABASE_URL="https://your-project-ref.supabase.co"
SUPABASE_ANON_KEY="your-supabase-anon-key"

# NextAuth.js
NEXTAUTH_URL="http://localhost:3000"
# Production: NEXTAUTH_URL="https://inphysic.com"
NEXTAUTH_SECRET="your-secret-key-here"

# Google OAuth
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Mux (for video streaming)
MUX_TOKEN_ID="your-mux-token-id"
MUX_TOKEN_SECRET="your-mux-token-secret"

# Google Cloud Storage Configuration (for file uploads)
GOOGLE_CLOUD_PROJECT_ID="your-project-id"
GOOGLE_CLOUD_KEY_FILE="path/to/service-account-key.json"
# OR use credentials JSON directly:
GOOGLE_CLOUD_CREDENTIALS='{"type":"service_account",...}'
GCS_BUCKET_NAME="your-gcs-bucket-name"
NEXT_PUBLIC_GCS_BUCKET_NAME="your-gcs-bucket-name"

# Uploadthing (for file uploads)
UPLOADTHING_SECRET="your-uploadthing-secret"
UPLOADTHING_APP_ID="your-uploadthing-app-id"

# Stripe (for payments)
STRIPE_API_KEY="your-stripe-api-key"
STRIPE_WEBHOOK_SECRET="your-stripe-webhook-secret"
