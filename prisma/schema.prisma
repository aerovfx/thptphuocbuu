// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  TEACHER
  STUDENT
  PARENT
  SUPER_ADMIN // IT quản trị hệ thống
  BGH // Ban Giám Hiệu
  BAN_TT // Ban Truyền Thông
  TRUONG_TONG // Trưởng Tổ
  QUAN_NHIEM // Quản nhiệm / Giáo viên chủ nhiệm
  TRUONG_HANH_CHINH // Trưởng hành chính
  BAO_VE // Bảo vệ
  LAO_CONG // Lao công
  DOAN_TN // Đoàn Thanh Niên
  DANG_BO // Đảng bộ
  TAI_CHINH // Ban Tài chính / Kế toán
  Y_TE // Ban Y tế
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  DELETED
  PENDING
}

enum PostType {
  TEXT
  IMAGE
  VIDEO
  LINK
}

enum DocumentType {
  ANNOUNCEMENT
  POLICY
  REPORT
  FORM
  OTHER
}

enum IncomingDocumentType {
  DIRECTIVE // Văn bản chỉ đạo
  RECORD // Hồ sơ
  REPORT // Tờ trình
  REQUEST // Đề nghị
  OTHER // Khác
}

enum DocumentStatus {
  PENDING // Chờ xử lý
  PROCESSING // Đang xử lý
  APPROVED // Đã phê duyệt
  REJECTED // Từ chối
  COMPLETED // Hoàn thành
  ARCHIVED // Lưu trữ
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  RETURNED // Trả lại
}

enum SignatureProvider {
  VNPT
  VIETTEL
  MISA
  INTERNAL // Ký nội bộ
}

enum BrandVerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum BrandMemberRole {
  OWNER
  ADMIN
  MEMBER
}

enum BrandBadgeType {
  GOLD // Verified Organization (Brand Premium)
  SILVER // Education/Non-profit
  BLUE // Premium Individual
}

model User {
  id                   String    @id @default(cuid())
  email                String    @unique
  password             String? // Optional for OAuth users
  firstName            String
  lastName             String
  avatar               String?
  coverPhoto           String? // Hình bìa hồ sơ
  role                 UserRole  @default(STUDENT)
  bio                  String?
  phone                String?
  dateOfBirth          DateTime?
  emailVerified        DateTime?
  resetPasswordToken   String?
  resetPasswordExpires DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  // OAuth accounts
  accounts Account[]
  sessions Session[]

  // LMS Relations
  enrolledClasses ClassEnrollment[]
  taughtClasses   Class[]           @relation("TeacherClasses")
  assignments     Assignment[]
  submissions     Submission[]
  teacherGrades   Grade[]           @relation("TeacherGrades")
  studentGrades   Grade[]           @relation("StudentGrades")
  announcements   Announcement[]

  // Social Media Relations
  posts                  Post[]          @relation("AuthorPosts")
  comments               Comment[]
  likes                  Like[]
  bookmarks              Bookmark[]
  reposts                Repost[]
  sentFriendRequests     FriendRequest[] @relation("Sender")
  receivedFriendRequests FriendRequest[] @relation("Receiver")
  friendships            Friendship[]    @relation("User1")
  friendships2           Friendship[]    @relation("User2")

  // Document Relations
  uploadedDocuments Document[]
  documentAccess    DocumentAccess[]

  // DMS Relations
  incomingDocumentsCreated  IncomingDocument[]           @relation("IncomingDocumentsCreated")
  incomingDocumentsAssigned IncomingDocumentAssignment[] @relation("IncomingDocumentsAssigned")
  outgoingDocumentsCreated  OutgoingDocument[]           @relation("OutgoingDocumentsCreated")
  workflowApprovals         Approval[]
  digitalSignatures         DigitalSignature[]           @relation("DigitalSignatures")

  // Brand Relations
  isPremium            Boolean               @default(false)
  brandId              String?
  ownedBrand           Brand?                @relation("BrandOwner")
  brandMemberships     BrandMember[]
  brandBadges          BrandBadge[]
  premiumSubscriptions PremiumSubscription[] @relation("PremiumSubscriptions")

  // Collaborative Document Relations
  ownedDocuments          CollaborativeDocument[] @relation("DocumentOwner")
  documentRevisions       DocumentRevision[]      @relation("DocumentRevisions")
  documentComments        DocumentComment[]       @relation("DocumentComments")
  documentPermissions     DocumentPermission[]    @relation("DocumentPermissions")
  workItemsCreated        WorkItem[]              @relation("WorkItemsCreated")
  documentVersionsCreated DocumentVersion[]       @relation("DocumentVersionsCreated")
  workflowAssignments     Workflow[]              @relation("WorkflowAssignments")
  taskAssignments         Task[]                  @relation("TaskAssignments")
  auditLogs               AuditLog[]              @relation("AuditLogs")
  newsArticles            NewsArticle[]           @relation("NewsArticles")

  // Messages Relations
  user1Conversations Conversation[] @relation("User1Conversations")
  user2Conversations Conversation[] @relation("User2Conversations")
  sentMessages       Message[]      @relation("SentMessages")

  // Admin Panel Relations
  status          UserStatus           @default(ACTIVE)
  lastLogin       DateTime?
  metadata        String? // JSON string for additional metadata
  userRoles       UserRoleAssignment[]
  createdRoles    Role[]               @relation("RoleCreator")
  assignedByRoles UserRoleAssignment[] @relation("AssignedByUser")
  adminAuditLogs  AdminAuditLog[]      @relation("AdminAuditLogs")

  // Organizational Structure Relations
  spaceMembers      SpaceMember[]
  departmentMembers DepartmentMember[]
  ledDepartments    Department[]       @relation("DepartmentLeaders")
  spaceProgressLogs SpaceProgressLog[] @relation("SpaceProgressLogs")
  spaceTasksCreated SpaceTask[]        @relation("SpaceTaskCreators")
  assignedTasks     SpaceTask[]        @relation("AssignedTasks")
  spaceTaskComments SpaceTaskComment[] @relation("SpaceTaskComments")
  spaceActivityLogs SpaceActivityLog[] @relation("SpaceActivityLogs")

  @@map("users")
}

model Class {
  id          String   @id @default(cuid())
  name        String
  code        String   @unique
  description String?
  subject     String
  grade       String
  teacherId   String
  teacher     User     @relation("TeacherClasses", fields: [teacherId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  enrollments   ClassEnrollment[]
  assignments   Assignment[]
  announcements Announcement[]
  chapters      Chapter[]

  @@map("classes")
}

model ClassEnrollment {
  id         String   @id @default(cuid())
  userId     String
  classId    String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  class      Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  enrolledAt DateTime @default(now())

  @@unique([userId, classId])
  @@map("class_enrollments")
}

model Assignment {
  id          String   @id @default(cuid())
  title       String
  description String?
  classId     String
  class       Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  teacherId   String
  teacher     User     @relation(fields: [teacherId], references: [id])
  dueDate     DateTime
  maxScore    Int      @default(100)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  submissions Submission[]

  @@map("assignments")
}

// Course Content Models
model Chapter {
  id          String   @id @default(cuid())
  title       String
  description String?
  order       Int      @default(0)
  classId     String
  class       Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  lessons Lesson[]

  @@map("chapters")
}

model Lesson {
  id          String   @id @default(cuid())
  title       String
  description String?
  content     String? // HTML content
  order       Int      @default(0)
  duration    Int? // Duration in minutes
  chapterId   String
  chapter     Chapter  @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("lessons")
}

model Submission {
  id           String     @id @default(cuid())
  assignmentId String
  assignment   Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  studentId    String
  student      User       @relation(fields: [studentId], references: [id])
  content      String?
  fileUrl      String?
  submittedAt  DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  grade Grade?

  @@unique([assignmentId, studentId])
  @@map("submissions")
}

model Grade {
  id           String     @id @default(cuid())
  submissionId String     @unique
  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  teacherId    String
  teacher      User       @relation("TeacherGrades", fields: [teacherId], references: [id])
  studentId    String
  student      User       @relation("StudentGrades", fields: [studentId], references: [id])
  score        Float
  feedback     String?
  gradedAt     DateTime   @default(now())

  @@map("grades")
}

model Announcement {
  id        String   @id @default(cuid())
  title     String
  content   String
  classId   String?
  class     Class?   @relation(fields: [classId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("announcements")
}

// Social Media Models
model Post {
  id           String    @id @default(cuid())
  content      String
  type         PostType  @default(TEXT)
  imageUrl     String?
  videoUrl     String?
  linkUrl      String?
  locationName String? // Tên địa điểm (ví dụ: "Hà Nội, Việt Nam")
  latitude     Float? // Vĩ độ
  longitude    Float? // Kinh độ
  scheduledAt  DateTime? // Thời gian lên lịch đăng bài (null = đăng ngay)
  authorId     String
  author       User      @relation("AuthorPosts", fields: [authorId], references: [id], onDelete: Cascade)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  comments  Comment[]
  likes     Like[]
  bookmarks Bookmark[]
  reposts   Repost[]

  @@map("posts")
}

model Comment {
  id        String   @id @default(cuid())
  content   String
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("comments")
}

model Like {
  id        String   @id @default(cuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([postId, userId])
  @@map("likes")
}

model Bookmark {
  id        String   @id @default(cuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([postId, userId])
  @@map("bookmarks")
}

model Repost {
  id        String   @id @default(cuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([postId, userId])
  @@index([userId, createdAt])
  @@map("reposts")
}

model FriendRequest {
  id         String   @id @default(cuid())
  senderId   String
  sender     User     @relation("Sender", fields: [senderId], references: [id], onDelete: Cascade)
  receiverId String
  receiver   User     @relation("Receiver", fields: [receiverId], references: [id], onDelete: Cascade)
  status     String   @default("PENDING") // PENDING, ACCEPTED, REJECTED
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([senderId, receiverId])
  @@map("friend_requests")
}

model Friendship {
  id        String   @id @default(cuid())
  user1Id   String
  user1     User     @relation("User1", fields: [user1Id], references: [id], onDelete: Cascade)
  user2Id   String
  user2     User     @relation("User2", fields: [user2Id], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([user1Id, user2Id])
  @@map("friendships")
}

// Document Management Models
model Document {
  id            String       @id @default(cuid())
  title         String
  description   String?
  fileName      String
  fileUrl       String
  fileSize      Int // in bytes
  mimeType      String
  type          DocumentType
  category      String?
  signedFileUrl String? // File đã ký số
  uploadedById  String
  uploadedBy    User         @relation(fields: [uploadedById], references: [id])
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  access     DocumentAccess[]
  signatures DigitalSignature[] @relation("DocumentSignatures")

  @@map("documents")
}

model DocumentAccess {
  id          String    @id @default(cuid())
  documentId  String
  document    Document  @relation(fields: [documentId], references: [id], onDelete: Cascade)
  userId      String?
  user        User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role        UserRole? // null means public access
  canView     Boolean   @default(true)
  canDownload Boolean   @default(false)
  createdAt   DateTime  @default(now())

  @@unique([documentId, userId])
  @@map("document_access")
}

// OAuth Account Model
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

// Session Model (optional, for database sessions)
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

// Verification Token Model
model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ============================================
// DMS Hành chính Models
// ============================================

// Loại văn bản hành chính (Standard Document Type Codes)
model AdministrativeDocumentType {
  code        String   @id // CV, QĐ, TB, BC, etc.
  name        String // Tên đầy đủ: Công văn, Quyết định, etc.
  group       String // inbound, outbound, administrative, internal, legal
  description String? // Mô tả chi tiết
  active      Boolean  @default(true)
  order       Int      @default(0) // Thứ tự hiển thị
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  incomingDocuments IncomingDocument[]
  outgoingDocuments OutgoingDocument[]

  @@map("document_types")
}

// Văn bản đến
model IncomingDocument {
  id             String               @id @default(cuid())
  documentNumber String? // Số văn bản
  documentCode   String? // Mã văn bản
  title          String
  content        String? // Nội dung trích xuất từ OCR
  summary        String? // Tóm tắt AI
  type           IncomingDocumentType @default(OTHER)
  status         DocumentStatus       @default(PENDING)

  // File info
  fileName        String
  fileUrl         String
  fileSize        Int
  mimeType        String
  originalFileUrl String? // File gốc trước OCR

  // OCR & AI
  ocrText         String? // Text trích xuất từ OCR
  ocrConfidence   Float? // Độ tin cậy OCR
  aiCategory      String? // Phân loại AI
  aiConfidence    Float? // Độ tin cậy AI
  aiExtractedData String? // JSON: dữ liệu trích xuất

  // Metadata
  sender       String? // Người/nơi gửi
  receivedDate DateTime  @default(now())
  priority     String    @default("NORMAL") // URGENT, HIGH, NORMAL, LOW
  deadline     DateTime?
  tags         String? // JSON array of tags: ["tag1", "tag2", ...]
  notes        String? // Ghi chú

  // Document Type
  documentTypeCode String? // Mã loại văn bản (CV, QĐ, TB, etc.)
  documentType     AdministrativeDocumentType? @relation(fields: [documentTypeCode], references: [code])

  // Relations
  createdById String
  createdBy   User                         @relation("IncomingDocumentsCreated", fields: [createdById], references: [id])
  assignments IncomingDocumentAssignment[]
  approvals   Approval[]
  aiResults   DocumentAI[]
  versions    DocumentVersion[]            @relation("DocumentVersions")
  workflows   Workflow[]                   @relation("IncomingDocumentWorkflows")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("incoming_documents")
}

// Phân công xử lý văn bản đến
model IncomingDocumentAssignment {
  id             String           @id @default(cuid())
  documentId     String
  document       IncomingDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  assignedToId   String
  assignedTo     User             @relation("IncomingDocumentsAssigned", fields: [assignedToId], references: [id])
  assignedById   String? // Người phân công
  notes          String? // Ghi chú phân công
  deadline       DateTime?
  status         DocumentStatus   @default(PENDING)
  completedAt    DateTime?
  checklistItems String? // JSON: array of checklist items

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("incoming_document_assignments")
}

// Văn bản đi
model OutgoingDocument {
  id             String  @id @default(cuid())
  documentNumber String? // Số văn bản (tự động)
  documentCode   String? // Mã văn bản
  title          String
  content        String // Nội dung văn bản
  aiDraft        String? // Bản nháp AI gợi ý
  template       String? // Mẫu sử dụng (NĐ 30)

  // File info
  fileName      String?
  fileUrl       String?
  fileSize      Int?
  mimeType      String?
  signedFileUrl String? // File đã ký số

  // Metadata
  recipient String? // Người/nơi nhận
  status    DocumentStatus @default(PENDING)
  priority  String         @default("NORMAL")
  sendDate  DateTime?
  tags      String? // JSON array of tags: ["tag1", "tag2", ...]

  // Workflow & Spaces
  targetSpaces    String? // JSON array of space IDs
  effectiveDate   DateTime? // Ngày có hiệu lực
  expiryDate      DateTime? // Ngày hết hiệu lực
  confidentiality String? // PUBLIC, INTERNAL, PRIVATE
  version         Int       @default(1)
  publishedAt     DateTime? // Thời gian publish
  archivedPdfUrl  String? // URL của PDF đã archive

  // Document Type
  documentTypeCode String? // Mã loại văn bản (CV, QĐ, TB, etc.)
  documentType     AdministrativeDocumentType? @relation(fields: [documentTypeCode], references: [code])

  // Relations
  createdById String
  createdBy   User               @relation("OutgoingDocumentsCreated", fields: [createdById], references: [id])
  approvals   Approval[]
  signatures  DigitalSignature[]
  workflows   Workflow[]         @relation("OutgoingDocumentWorkflows")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([publishedAt])
  @@index([effectiveDate])
  @@map("outgoing_documents")
}

// Luồng phê duyệt
model Approval {
  id String @id @default(cuid())

  // Document reference (polymorphic)
  incomingDocumentId String?
  incomingDocument   IncomingDocument? @relation(fields: [incomingDocumentId], references: [id], onDelete: Cascade)
  outgoingDocumentId String?
  outgoingDocument   OutgoingDocument? @relation(fields: [outgoingDocumentId], references: [id], onDelete: Cascade)
  workItemId         String?
  workItem           WorkItem?         @relation(fields: [workItemId], references: [id], onDelete: Cascade)

  // Approval info
  level      Int // Cấp phê duyệt (1, 2, 3...)
  approverId String
  approver   User           @relation(fields: [approverId], references: [id])
  status     ApprovalStatus @default(PENDING)
  comment    String? // Ý kiến phê duyệt
  approvedAt DateTime?

  // Deadline
  deadline       DateTime?
  reminderSent   Boolean   @default(false)
  reminderSentAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("approvals")
}

// Hồ sơ công việc
model WorkItem {
  id          String         @id @default(cuid())
  title       String
  description String?
  content     String? // Nội dung chi tiết
  status      DocumentStatus @default(PENDING)
  priority    String         @default("NORMAL")

  // Deadline & reminders
  deadline       DateTime?
  reminderDays   Int? // Số ngày nhắc trước deadline
  lastReminderAt DateTime?

  // Relations
  createdById String
  createdBy   User       @relation("WorkItemsCreated", fields: [createdById], references: [id])
  approvals   Approval[]

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  completedAt DateTime?

  @@map("work_items")
}

// Ký số & xác thực
model DigitalSignature {
  id String @id @default(cuid())

  // Document reference (polymorphic)
  documentId         String? // General Document
  document           Document?         @relation("DocumentSignatures", fields: [documentId], references: [id], onDelete: Cascade)
  outgoingDocumentId String?
  outgoingDocument   OutgoingDocument? @relation(fields: [outgoingDocumentId], references: [id], onDelete: Cascade)

  // Signature info
  provider        SignatureProvider
  certificateId   String? // ID chứng thư số
  certificateInfo String? // JSON: thông tin chứng thư
  signedBy        String // Người ký
  signedById      String
  signedByUser    User              @relation("DigitalSignatures", fields: [signedById], references: [id])

  // Signature data
  signatureHash    String? // Hash chữ ký
  signatureFileUrl String? // File chữ ký
  timestamp        DateTime? // Thời gian ký

  // Status
  isValid      Boolean   @default(true)
  verifiedAt   DateTime?
  errorMessage String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("digital_signatures")
}

// AI Processing Results
model DocumentAI {
  id         String           @id @default(cuid())
  documentId String
  document   IncomingDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  // AI Results
  aiType         String // OCR, CLASSIFY, EXTRACT, SUMMARIZE, SEARCH
  result         String // JSON: kết quả AI
  confidence     Float?
  model          String? // Model AI sử dụng
  processingTime Int? // Thời gian xử lý (ms)

  // Related documents (semantic search)
  relatedDocIds String? // JSON: IDs tài liệu liên quan

  createdAt DateTime @default(now())

  @@map("document_ai")
}

// Document Versions (for version control)
model DocumentVersion {
  id         String           @id @default(cuid())
  documentId String
  document   IncomingDocument @relation("DocumentVersions", fields: [documentId], references: [id], onDelete: Cascade)

  // Version info
  versionNumber Int    @default(1)
  fileUrl       String
  fileName      String
  fileSize      Int
  mimeType      String

  // OCR & AI
  ocrText         String? // Text trích xuất từ OCR
  extractedTextId String? // Reference to OCRExtract

  // Metadata
  createdById String
  createdBy   User    @relation("DocumentVersionsCreated", fields: [createdById], references: [id])
  changeNote  String? // Ghi chú thay đổi

  createdAt DateTime @default(now())

  @@unique([documentId, versionNumber])
  @@map("document_versions")
}

// Workflow Engine
model Workflow {
  id String @id @default(cuid())

  // Document reference
  incomingDocumentId String?
  incomingDocument   IncomingDocument? @relation("IncomingDocumentWorkflows", fields: [incomingDocumentId], references: [id], onDelete: Cascade)
  outgoingDocumentId String?
  outgoingDocument   OutgoingDocument? @relation("OutgoingDocumentWorkflows", fields: [outgoingDocumentId], references: [id], onDelete: Cascade)

  // Workflow definition
  name        String
  steps       String // JSON: array of workflow steps
  currentStep Int    @default(0)
  status      String @default("PENDING") // PENDING, IN_PROGRESS, COMPLETED, CANCELLED

  // Auto-routing
  autoAssigned Boolean @default(false)
  assignedToId String?
  assignedTo   User?   @relation("WorkflowAssignments", fields: [assignedToId], references: [id])

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  completedAt DateTime?

  tasks Task[]

  @@map("workflows")
}

// Workflow Tasks
model Task {
  id         String   @id @default(cuid())
  workflowId String
  workflow   Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  // Task info
  stepNumber  Int
  title       String
  description String?
  assigneeId  String
  assignee    User    @relation("TaskAssignments", fields: [assigneeId], references: [id])

  // Status
  status      String    @default("PENDING") // PENDING, IN_PROGRESS, COMPLETED, REJECTED
  dueDate     DateTime?
  completedAt DateTime?

  // Notes
  notes       String?
  attachments String? // JSON: array of file URLs

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("tasks")
}

// Audit Log (immutable)
model AuditLog {
  id String @id @default(cuid())

  // User & Action
  userId String
  user   User   @relation("AuditLogs", fields: [userId], references: [id])
  action String // CREATE, UPDATE, DELETE, APPROVE, REJECT, SIGN, etc.

  // Document reference
  incomingDocumentId String?
  outgoingDocumentId String?
  workflowId         String?
  taskId             String?

  // Payload
  payload   String // JSON: chi tiết thay đổi
  ipAddress String?
  userAgent String?

  // Immutability
  hash String? // Hash của log để đảm bảo tính toàn vẹn

  timestamp DateTime @default(now())

  @@index([userId])
  @@index([incomingDocumentId])
  @@index([outgoingDocumentId])
  @@index([timestamp])
  @@map("audit_logs")
}

// ============================================
// News & Media Models
// ============================================

enum NewsCategory {
  EDUCATION
  RESEARCH
  INNOVATION
  CAMPUS_LIFE
  ALUMNI
  EVENTS
  ANNOUNCEMENTS
  GENERAL
}

enum NewsStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model NewsArticle {
  id            String       @id @default(cuid())
  title         String
  slug          String       @unique
  excerpt       String? // Tóm tắt ngắn
  content       String // Nội dung đầy đủ (Markdown hoặc HTML)
  featuredImage String? // URL ảnh đại diện
  category      NewsCategory @default(GENERAL)
  status        NewsStatus   @default(DRAFT)

  // Metadata
  authorId   String
  author     User    @relation("NewsArticles", fields: [authorId], references: [id])
  views      Int     @default(0)
  isFeatured Boolean @default(false)
  isTopNews  Boolean @default(false)

  // SEO
  metaTitle       String?
  metaDescription String?
  tags            String? // JSON array of tags

  // Relations
  departmentId String?
  department   NewsDepartment? @relation(fields: [departmentId], references: [id])

  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([category])
  @@index([status])
  @@index([publishedAt])
  @@map("news_articles")
}

model NewsDepartment {
  id          String  @id @default(cuid())
  name        String  @unique
  slug        String  @unique
  description String?
  icon        String? // Icon name hoặc URL
  order       Int     @default(0)

  articles NewsArticle[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("news_departments")
}

// ============================================
// Messages & Conversations Models
// ============================================

// Conversation (1-on-1 chat)
model Conversation {
  id String @id @default(cuid())

  // Participants
  user1Id String
  user1   User   @relation("User1Conversations", fields: [user1Id], references: [id], onDelete: Cascade)
  user2Id String
  user2   User   @relation("User2Conversations", fields: [user2Id], references: [id], onDelete: Cascade)

  // Last message info (for quick access)
  lastMessageId String?
  lastMessage   Message?  @relation("LastMessage", fields: [lastMessageId], references: [id])
  lastMessageAt DateTime?

  // Unread counts per user
  user1UnreadCount Int @default(0)
  user2UnreadCount Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages Message[]

  @@unique([user1Id, user2Id])
  @@index([user1Id, updatedAt])
  @@index([user2Id, updatedAt])
  @@map("conversations")
}

// Message
model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  // Sender
  senderId String
  sender   User   @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)

  // Content
  content  String
  imageUrl String? // Optional image attachment
  isRead   Boolean   @default(false)
  readAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relation for last message
  lastMessageConversations Conversation[] @relation("LastMessage")

  @@index([conversationId, createdAt])
  @@index([senderId])
  @@map("messages")
}

// Brand Management Models
model Brand {
  id                 String                  @id @default(cuid())
  name               String
  slug               String                  @unique
  logoUrl            String?
  website            String?
  description        String?
  emailDomain        String? // Verified email domain (e.g., @company.com)
  businessLicense    String? // URL to business license document
  verificationStatus BrandVerificationStatus @default(PENDING)
  createdById        String                  @unique
  createdBy          User                    @relation("BrandOwner", fields: [createdById], references: [id], onDelete: Cascade)
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt

  // Relations
  members BrandMember[]
  badges  BrandBadge[]

  @@index([createdById])
  @@index([slug])
  @@map("brands")
}

model BrandMember {
  id          String          @id @default(cuid())
  brandId     String
  brand       Brand           @relation(fields: [brandId], references: [id], onDelete: Cascade)
  userId      String
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  role        BrandMemberRole @default(MEMBER)
  permissions Json? // Custom permissions as JSON
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@unique([brandId, userId])
  @@index([brandId])
  @@index([userId])
  @@map("brand_members")
}

model BrandBadge {
  id           String         @id @default(cuid())
  brandId      String
  brand        Brand          @relation(fields: [brandId], references: [id], onDelete: Cascade)
  userId       String
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  badgeType    BrandBadgeType
  badgeIconUrl String? // Custom badge icon URL
  isActive     Boolean        @default(true)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@unique([brandId, userId])
  @@index([brandId])
  @@index([userId])
  @@map("brand_badges")
}

// Premium Subscription Model
model PremiumSubscription {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation("PremiumSubscriptions", fields: [userId], references: [id], onDelete: Cascade)
  plan           String // STANDARD, PRO, ENTERPRISE
  status         String   @default("ACTIVE") // ACTIVE, EXPIRED, CANCELLED
  startDate      DateTime @default(now())
  endDate        DateTime // 1 month from startDate
  activatedBy    String   @default("TASKS") // TASKS (auto), MANUAL (user subscribed)
  completedTasks Int      @default(0) // Number of tasks completed to activate
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([endDate])
  @@map("premium_subscriptions")
}

// Collaborative Document Editor Models (Google Docs-like)
enum DocumentPermissionRole {
  OWNER
  EDITOR
  COMMENTER
  VIEWER
}

model CollaborativeDocument {
  id           String    @id @default(cuid())
  title        String
  content      Json? // CRDT snapshot or AST
  ownerId      String
  owner        User      @relation("DocumentOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  lastEditedAt DateTime?
  lastEditedBy String?

  // Relations
  revisions   DocumentRevision[]
  comments    DocumentComment[]
  permissions DocumentPermission[]

  @@index([ownerId])
  @@index([updatedAt])
  @@map("collaborative_documents")
}

model DocumentRevision {
  id          String                @id @default(cuid())
  documentId  String
  document    CollaborativeDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  delta       Json? // Operational Transform delta or CRDT changes
  snapshot    Json? // Full document snapshot at this revision
  userId      String?
  user        User?                 @relation("DocumentRevisions", fields: [userId], references: [id], onDelete: SetNull)
  description String? // Optional description of changes
  createdAt   DateTime              @default(now())

  @@index([documentId, createdAt])
  @@map("document_revisions")
}

model DocumentComment {
  id         String                @id @default(cuid())
  documentId String
  document   CollaborativeDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  userId     String
  user       User                  @relation("DocumentComments", fields: [userId], references: [id], onDelete: Cascade)
  content    String
  position   Json? // Position in document (e.g., { blockId, offset })
  resolved   Boolean               @default(false)
  resolvedAt DateTime?
  resolvedBy String?
  replies    Json? // Nested replies as JSON
  createdAt  DateTime              @default(now())
  updatedAt  DateTime              @updatedAt

  @@index([documentId])
  @@index([userId])
  @@map("document_comments")
}

model DocumentPermission {
  id         String                 @id @default(cuid())
  documentId String
  document   CollaborativeDocument  @relation(fields: [documentId], references: [id], onDelete: Cascade)
  userId     String
  user       User                   @relation("DocumentPermissions", fields: [userId], references: [id], onDelete: Cascade)
  role       DocumentPermissionRole @default(VIEWER)
  createdAt  DateTime               @default(now())
  updatedAt  DateTime               @updatedAt

  @@unique([documentId, userId])
  @@index([documentId])
  @@index([userId])
  @@map("document_permissions")
}

// ============================================
// Admin Panel Models - RBAC & Module Management
// ============================================

// Role Model
model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String
  createdBy   User     @relation("RoleCreator", fields: [createdById], references: [id])

  // Relations
  rolePermissions RolePermission[]
  userAssignments UserRoleAssignment[]

  @@map("roles")
}

// Permission Model
model Permission {
  id          String   @id @default(cuid())
  resource    String // e.g. "module:user", "module:report"
  action      String // e.g. "read", "write", "delete", "export"
  description String?
  createdAt   DateTime @default(now())

  // Relations
  rolePermissions RolePermission[]

  @@unique([resource, action])
  @@index([resource])
  @@map("permissions")
}

// RolePermission (many-to-many)
model RolePermission {
  id           String     @id @default(cuid())
  roleId       String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  attributes   String? // JSON string for ABAC rules (optional)
  createdAt    DateTime   @default(now())

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
  @@map("role_permissions")
}

// UserRoleAssignment (many-to-many with metadata)
model UserRoleAssignment {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  roleId       String
  role         Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  assignedById String
  assignedBy   User     @relation("AssignedByUser", fields: [assignedById], references: [id])
  assignedAt   DateTime @default(now())

  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
  @@map("user_roles")
}

// Module Model
model Module {
  id          String   @id @default(cuid())
  key         String   @unique // e.g. "user_mgmt", "report_module"
  name        String
  description String?
  enabled     Boolean  @default(false)
  config      String? // JSON string for module configuration
  version     String   @default("1.0.0")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([key])
  @@index([enabled])
  @@map("modules")
}

// Admin Audit Log (extended from existing AuditLog)
model AdminAuditLog {
  id         String   @id @default(cuid())
  actorId    String // Admin user who performed the action
  actor      User     @relation("AdminAuditLogs", fields: [actorId], references: [id])
  action     String // "user.create", "module.update", "role.assign", etc.
  targetType String? // "user", "role", "module", "permission"
  targetId   String? // ID of the target resource
  details    String? // JSON string with action details
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([actorId])
  @@index([action])
  @@index([targetType, targetId])
  @@index([createdAt])
  @@map("admin_audit_logs")
}

// ============================================
// Organizational Structure Models
// ============================================

enum SpaceType {
  SCHOOL_HUB // Public hub
  BGH_SPACE // Ban Giám Hiệu (private)
  BAN_TT // Ban Truyền Thông (semi-public)
  TO_CHUYEN_MON // Tổ Chuyên Môn (private)
  TO_HANH_CHINH // Tổ Hành chính
  BAO_VE // Bảo vệ
  LAO_CONG // Lao công
  LOP // Lớp học (per-class)
  DOAN_DANG // Đoàn / Đảng bộ
  TAI_CHINH // Ban Tài chính
  Y_TE // Ban Y tế
  PUBLIC_NEWS // Public News / Gallery
}

enum SpaceVisibility {
  PUBLIC // Công khai
  INTERNAL // Nội bộ
  PRIVATE // Riêng tư
}

enum DepartmentType {
  TO_CHUYEN_MON // Tổ Chuyên Môn (Toán, Văn, etc.)
  TO_HANH_CHINH // Tổ Hành chính
  BAN_TT // Ban Truyền Thông
  BAN_TAI_CHINH // Ban Tài chính
  BAN_Y_TE // Ban Y tế
  DOAN_DANG // Đoàn / Đảng bộ
  OTHER // Khác
}

// Space - Không gian làm việc
model Space {
  id          String          @id @default(cuid())
  name        String
  code        String          @unique
  description String?
  type        SpaceType
  visibility  SpaceVisibility @default(INTERNAL)
  parentId    String? // Parent space (hierarchical)
  parent      Space?          @relation("SpaceHierarchy", fields: [parentId], references: [id])
  children    Space[]         @relation("SpaceHierarchy")

  // Metadata
  icon     String?
  color    String? // Màu hiển thị
  order    Int     @default(0)
  isActive Boolean @default(true)

  // Timeline & Progress
  startDate    DateTime? // Ngày bắt đầu hoạt động
  endDate      DateTime? // Ngày kết thúc hoạt động
  progress     Int       @default(0) // Tiến độ (0-100)
  academicYear String? // Năm học (format: YYYY-YYYY+1, ví dụ: 2025-2026)
  archivedAt   DateTime? // Ngày lưu trữ (khi progress đạt 100%)

  // Overview Content (JSON) - Deprecated, use dedicated models below
  overview String? // JSON object containing: mission, members, workflow, tools, timelines, rules, kpis, resources, security

  // Agile/Scrum Framework
  framework       String?      @default("AGILE") // AGILE, SCRUM, KANBAN, WATERFALL
  sprintDuration  Int?         @default(14) // Sprint duration in days (default 2 weeks)
  currentSprintId String? // Current active sprint
  currentSprint   SpaceSprint? @relation("CurrentSprint", fields: [currentSprintId], references: [id])

  // Relations
  members      SpaceMember[]
  departments  Department[]
  documents    SpaceDocument[]
  progressLogs SpaceProgressLog[]
  tasks        SpaceTask[]

  // 8 Core Criteria + 2 Additional
  mission      SpaceMission?
  workflows    SpaceWorkflow[]
  tools        SpaceTool[]
  rules        SpaceRule[]
  kpis         SpaceKPI[]
  resources    SpaceResource[]
  sprints      SpaceSprint[]      @relation("SpaceSprints")
  timelines    SpaceTimeline[]
  security     SpaceSecurity?
  activityLogs SpaceActivityLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
  @@index([parentId])
  @@index([isActive])
  @@index([startDate])
  @@index([endDate])
  @@index([academicYear])
  @@index([archivedAt])
  @@map("spaces")
}

// Space Progress Log - Nhật ký tiến độ của Space
model SpaceProgressLog {
  id      String @id @default(cuid())
  spaceId String
  space   Space  @relation(fields: [spaceId], references: [id], onDelete: Cascade)

  // Progress data
  progress    Int     @default(0) // Tiến độ tại thời điểm này (0-100)
  milestone   String? // Mốc tiến độ (ví dụ: "Hoàn thành giai đoạn 1")
  description String? // Mô tả chi tiết
  checklist   String? // JSON array of checklist items: [{"id": "1", "text": "Task 1", "completed": false}]
  order       Int     @default(0) // Order in the board

  // Metadata
  createdById String
  createdBy   User     @relation("SpaceProgressLogs", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())

  @@index([spaceId])
  @@index([createdAt])
  @@map("space_progress_logs")
}

// Space Task - Công việc trong Space (Jira-style)
model SpaceTask {
  id      String @id @default(cuid())
  spaceId String
  space   Space  @relation(fields: [spaceId], references: [id], onDelete: Cascade)

  // Task content
  title       String
  description String?
  column      String    @default("todo") // Column name: todo, in-progress, review, done, etc.
  order       Int       @default(0) // Order within column
  priority    String?   @default("NORMAL") // LOW, NORMAL, HIGH, URGENT
  dueDate     DateTime?

  // Rich content
  images      String? // JSON array of image URLs
  attachments String? // JSON array of attachment objects: [{"name": "...", "url": "...", "type": "..."}]
  checklist   String? // JSON array: [{"id": "...", "text": "...", "completed": false}]
  tags        String? // JSON array of tag strings

  // Metadata
  createdById  String
  createdBy    User    @relation("SpaceTaskCreators", fields: [createdById], references: [id])
  assignedToId String?
  assignedTo   User?   @relation("AssignedTasks", fields: [assignedToId], references: [id])

  // Comments
  comments      SpaceTaskComment[]
  commentsCount Int                @default(0) // Denormalized for performance

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([spaceId])
  @@index([column])
  @@index([createdById])
  @@index([assignedToId])
  @@index([dueDate])
  @@map("space_tasks")
}

// Space Task Comment - Bình luận trên task
model SpaceTaskComment {
  id     String    @id @default(cuid())
  taskId String
  task   SpaceTask @relation(fields: [taskId], references: [id], onDelete: Cascade)

  content     String
  createdById String
  createdBy   User   @relation("SpaceTaskComments", fields: [createdById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([taskId])
  @@index([createdAt])
  @@map("space_task_comments")
}

// Space Member - Thành viên & vai trò trong space
model SpaceMember {
  id      String @id @default(cuid())
  spaceId String
  space   Space  @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  userId  String
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Role in this space
  role            String  @default("MEMBER") // OWNER, ADMIN, MODERATOR, MEMBER, VIEWER, LEADER, DESIGNER, EDITOR, WRITER, etc.
  roleDescription String? // Mô tả vai trò cụ thể - Ví dụ: "Quản lý tiến độ & phê duyệt nội dung"
  canRead         Boolean @default(true)
  canWrite        Boolean @default(false)
  canManage       Boolean @default(false)
  canApprove      Boolean @default(false) // Quyền phê duyệt
  canPublish      Boolean @default(false) // Quyền xuất bản

  // Metadata
  joinedAt  DateTime @default(now())
  invitedBy String? // User ID who invited

  @@unique([spaceId, userId])
  @@index([spaceId])
  @@index([userId])
  @@index([role])
  @@map("space_members")
}

// Department / Team - Tổ chuyên môn
model Department {
  id          String         @id @default(cuid())
  name        String
  code        String         @unique
  description String?
  type        DepartmentType
  spaceId     String? // Space mà tổ này thuộc về
  space       Space?         @relation(fields: [spaceId], references: [id])

  // Leader
  leaderId String? // Trưởng tổ
  leader   User?   @relation("DepartmentLeaders", fields: [leaderId], references: [id])

  // Subject/Subject area (for Tổ Chuyên Môn)
  subject String? // Toán, Văn, Lý, Hóa, etc.

  // Metadata
  icon     String?
  color    String?
  order    Int     @default(0)
  isActive Boolean @default(true)

  // Relations
  members   DepartmentMember[]
  documents DepartmentDocument[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
  @@index([spaceId])
  @@index([leaderId])
  @@index([subject])
  @@map("departments")
}

// Department Member - Thành viên trong tổ
model DepartmentMember {
  id           String     @id @default(cuid())
  departmentId String
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Role in department
  role     String  @default("MEMBER") // LEADER, DEPUTY, MEMBER
  isActive Boolean @default(true)

  joinedAt DateTime @default(now())

  @@unique([departmentId, userId])
  @@index([departmentId])
  @@index([userId])
  @@map("department_members")
}

// Space Document - Văn bản gắn với space
// Note: documentId là polymorphic reference (có thể là OutgoingDocument hoặc IncomingDocument)
// Không thể tạo foreign key trực tiếp, chỉ lưu ID và type
model SpaceDocument {
  id           String          @id @default(cuid())
  spaceId      String
  space        Space           @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  documentId   String // Reference to OutgoingDocument or IncomingDocument (polymorphic)
  documentType String // "OUTGOING" | "INCOMING"
  visibility   SpaceVisibility @default(INTERNAL)
  assignedAt   DateTime        @default(now())

  @@unique([spaceId, documentId, documentType])
  @@index([spaceId])
  @@index([documentId, documentType])
  @@map("space_documents")
}

// Department Document - Văn bản gắn với tổ
model DepartmentDocument {
  id           String     @id @default(cuid())
  departmentId String
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  documentId   String
  documentType String // "OUTGOING" | "INCOMING"

  createdAt DateTime @default(now())

  @@unique([departmentId, documentId, documentType])
  @@index([departmentId])
  @@index([documentId, documentType])
  @@map("department_documents")
}

// ============================================
// Space 8 Core Criteria Models (Agile/Scrum Framework)
// ============================================

// 1. Mission & Scope - Sứ mệnh và phạm vi hoạt động của Space
model SpaceMission {
  id      String @id @default(cuid())
  spaceId String @unique
  space   Space  @relation(fields: [spaceId], references: [id], onDelete: Cascade)

  // Mission content
  vision         String? // Tầm nhìn
  mission        String // Sứ mệnh - Space được tạo ra để làm gì?
  scope          String? // Phạm vi hoạt động - Đang phụ trách mảng/nhánh nào?
  expectedOutput String? // Kết quả đầu ra mong muốn
  objectives     String? // JSON array: ["objective1", "objective2"]
  values         String? // JSON array: ["value1", "value2"]
  description    String? // Mô tả chi tiết

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("space_missions")
}

// 2. Workflow/SOP - Quy trình làm việc chuẩn (Agile/Scrum)
model SpaceWorkflow {
  id      String @id @default(cuid())
  spaceId String
  space   Space  @relation(fields: [spaceId], references: [id], onDelete: Cascade)

  // Workflow definition
  name        String // Tên quy trình
  type        String  @default("SCRUM") // SCRUM, KANBAN, CUSTOM, SOP
  description String? // Mô tả quy trình

  // Workflow steps (JSON) - Các bước chi tiết
  // Format: [{"id": "1", "name": "Nhận yêu cầu", "order": 1, "description": "...", "assignee": "..."}, ...]
  steps String? // JSON array: [{"id": "1", "name": "Nhận yêu cầu", "order": 1, "description": "...", "assignee": "..."}, ...]

  // SOP Details - Quy trình chuẩn
  sopContent String? // Nội dung SOP chi tiết (Markdown)
  diagramUrl String? // Link đến sơ đồ quy trình (nếu có)

  // Scrum-specific
  sprintDuration    Int?    @default(14) // Days
  dailyStandupTime  String? // "09:00"
  sprintPlanningDay String? // "Monday"
  retrospectiveDay  String? // "Friday"

  isActive Boolean @default(true)
  order    Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([spaceId])
  @@index([isActive])
  @@map("space_workflows")
}

// 3. Tools - Công cụ sử dụng
model SpaceTool {
  id      String @id @default(cuid())
  spaceId String
  space   Space  @relation(fields: [spaceId], references: [id], onDelete: Cascade)

  // Tool info
  name        String
  category    String? // DEVELOPMENT, COMMUNICATION, PROJECT_MANAGEMENT, etc.
  description String?
  url         String? // Link to tool
  icon        String? // Icon URL or name

  // Configuration
  config String? // JSON: tool-specific configuration

  isActive Boolean @default(true)
  order    Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([spaceId])
  @@index([category])
  @@map("space_tools")
}

// 4. Rules - Quy tắc phối hợp & chuẩn giao tiếp
model SpaceRule {
  id      String @id @default(cuid())
  spaceId String
  space   Space  @relation(fields: [spaceId], references: [id], onDelete: Cascade)

  // Rule content
  title       String
  description String?
  category    String? // COMMUNICATION, FILE_MANAGEMENT, REPORTING, CODE_REVIEW, COMMIT, MEETING, etc.
  content     String // Nội dung quy tắc (Markdown) - Ví dụ: "Nhắn việc => tag đúng người", "Mọi file phải lưu vào thư mục chuẩn"

  // Enforcement
  isRequired Boolean @default(false) // Bắt buộc hay không
  priority   String  @default("NORMAL") // HIGH, NORMAL, LOW

  isActive Boolean @default(true)
  order    Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([spaceId])
  @@index([category])
  @@index([isActive])
  @@map("space_rules")
}

// 5. KPIs - Chỉ số đánh giá
model SpaceKPI {
  id      String @id @default(cuid())
  spaceId String
  space   Space  @relation(fields: [spaceId], references: [id], onDelete: Cascade)

  // KPI definition
  name        String
  description String?
  category    String? // VELOCITY, QUALITY, EFFICIENCY, SATISFACTION, etc.

  // Measurement
  targetValue       Float? // Giá trị mục tiêu
  currentValue      Float? // Giá trị hiện tại
  unit              String? // "points", "hours", "%", etc.
  measurementPeriod String? @default("SPRINT") // SPRINT, MONTH, QUARTER, YEAR

  // Tracking
  formula    String? // Công thức tính (nếu có)
  dataSource String? // Nguồn dữ liệu

  isActive Boolean @default(true)
  order    Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // History tracking
  history SpaceKPIHistory[]

  @@index([spaceId])
  @@index([category])
  @@index([isActive])
  @@map("space_kpis")
}

// KPI History - Lịch sử giá trị KPI
model SpaceKPIHistory {
  id    String   @id @default(cuid())
  kpiId String
  kpi   SpaceKPI @relation(fields: [kpiId], references: [id], onDelete: Cascade)

  value      Float
  recordedAt DateTime @default(now())
  notes      String?

  @@index([kpiId])
  @@index([recordedAt])
  @@map("space_kpi_history")
}

// 6. Resources - Tài liệu quan trọng / Mẫu biểu (Templates & Resources)
model SpaceResource {
  id      String @id @default(cuid())
  spaceId String
  space   Space  @relation(fields: [spaceId], references: [id], onDelete: Cascade)

  // Resource info
  name        String
  type        String // DOCUMENT, LINK, TOOL, TEMPLATE, BRAND_GUIDE, POLICY, etc.
  description String?
  url         String? // Link to resource
  fileUrl     String? // File attachment URL

  // Metadata
  category String? // TEMPLATE, DOCUMENTATION, BRAND_GUIDE, POLICY, REFERENCE, etc.
  tags     String? // JSON array of tags
  isPublic Boolean @default(false) // Có thể chia sẻ công khai không

  // Template-specific
  templateType String? // WRITING_TEMPLATE, REPORT_TEMPLATE, etc.
  usage        String? // Hướng dẫn sử dụng template

  isActive Boolean @default(true)
  order    Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([spaceId])
  @@index([type])
  @@index([category])
  @@index([templateType])
  @@map("space_resources")
}

// 7. Timeline - Lịch làm việc & deadline cố định
model SpaceTimeline {
  id      String @id @default(cuid())
  spaceId String
  space   Space  @relation(fields: [spaceId], references: [id], onDelete: Cascade)

  // Timeline item
  title       String
  description String?
  type        String  @default("MILESTONE") // MILESTONE, EVENT, DEADLINE, RELEASE, MEETING, REPORT, PUBLISH_CYCLE

  // Dates
  startDate DateTime?
  endDate   DateTime?
  dueDate   DateTime? // Deadline

  // Recurring schedule (for fixed deadlines)
  isRecurring       Boolean @default(false) // Lặp lại định kỳ
  recurrencePattern String? // JSON: {"type": "WEEKLY", "dayOfWeek": 1, "time": "09:00"} hoặc {"type": "MONTHLY", "day": 1}
  // WEEKLY, MONTHLY, DAILY, etc.

  // Status
  status String @default("PLANNED") // PLANNED, IN_PROGRESS, COMPLETED, CANCELLED

  // Relations
  relatedSprintId String? // Link to sprint if applicable
  relatedTaskIds  String? // JSON array of task IDs

  isActive Boolean @default(true)
  order    Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([spaceId])
  @@index([type])
  @@index([status])
  @@index([startDate])
  @@index([dueDate])
  @@index([isRecurring])
  @@map("space_timelines")
}

// 8. Sprint - Sprint trong Scrum
model SpaceSprint {
  id      String @id @default(cuid())
  spaceId String
  space   Space  @relation("SpaceSprints", fields: [spaceId], references: [id], onDelete: Cascade)

  // Current sprint relation (one-to-many: one sprint can be current for multiple spaces)
  currentSpaces Space[] @relation("CurrentSprint")

  // Sprint info
  name        String
  number      Int // Sprint number (1, 2, 3...)
  description String?

  // Dates
  startDate     DateTime
  endDate       DateTime
  actualEndDate DateTime? // Ngày kết thúc thực tế

  // Goals
  goal        String? // Sprint goal
  userStories String? // JSON array of user story IDs

  // Status
  status String @default("PLANNED") // PLANNED, ACTIVE, COMPLETED, CANCELLED

  // Metrics
  plannedVelocity Int? // Story points planned
  actualVelocity  Int? // Story points completed
  burndownData    String? // JSON: burndown chart data

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([spaceId, number])
  @@index([spaceId])
  @@index([status])
  @@index([startDate])
  @@map("space_sprints")
}

// 9. Security & Access - Quy định bảo mật & quyền truy cập
model SpaceSecurity {
  id      String @id @default(cuid())
  spaceId String @unique
  space   Space  @relation(fields: [spaceId], references: [id], onDelete: Cascade)

  // Security rules
  confidentialityLevel String  @default("INTERNAL") // PUBLIC, INTERNAL, CONFIDENTIAL, SECRET
  dataSharingRules     String? // Quy định chia sẻ dữ liệu (Markdown)
  // Ví dụ: "Nội dung nội bộ không được chia sẻ ngoài Space"

  // Access control
  approvalRequired Boolean @default(false) // Cần phê duyệt trước khi xuất bản
  approvalRoles    String? // JSON array: ["ADMIN", "LEADER"] - Ai được phép phê duyệt
  publishRoles     String? // JSON array: ["ADMIN", "LEADER"] - Ai được phép xuất bản

  // External sharing
  allowExternalSharing Boolean @default(false)
  externalSharingRules String? // Quy định chia sẻ với bên ngoài

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("space_securities")
}

// 10. Activity Log - Dòng thời gian hoạt động (Activity Timeline/Log)
model SpaceActivityLog {
  id      String @id @default(cuid())
  spaceId String
  space   Space  @relation(fields: [spaceId], references: [id], onDelete: Cascade)

  // Activity content
  title       String // Tiêu đề hoạt động
  description String? // Mô tả chi tiết (1-2 dòng)
  type        String  @default("UPDATE") // UPDATE, COMPLETED, IN_PROGRESS, PLANNED, MILESTONE

  // Status summary
  completedItems  String? // JSON array: ["Việc đã hoàn thành 1", "Việc đã hoàn thành 2"]
  inProgressItems String? // JSON array: ["Việc đang xử lý 1", "Việc đang xử lý 2"]
  plannedItems    String? // JSON array: ["Việc sắp làm 1", "Việc sắp làm 2"]

  // Period
  periodStart DateTime? // Bắt đầu kỳ (tuần/tháng)
  periodEnd   DateTime? // Kết thúc kỳ
  periodType  String? // WEEK, MONTH, QUARTER, YEAR

  // Metadata
  createdById String
  createdBy   User   @relation("SpaceActivityLogs", fields: [createdById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([spaceId])
  @@index([type])
  @@index([periodStart])
  @@index([createdAt])
  @@map("space_activity_logs")
}
